{
  "info": {
    "name": "Node Backend API",
    "description": "Complete API collection for the Node backend.\n\nSetup:\n1. Run `bun run db:seed` to populate test data\n2. Send the \"Login (Alice)\" request — tokens are auto-saved\n3. All authenticated requests will use the saved token automatically\n\nTest accounts (password: password123):\n- alice@example.com (verified)\n- bob@example.com (verified)\n- charlie@example.com (verified)\n- diana@example.com (verified)\n- eve@example.com (verified)\n- frank@example.com (unverified, OTP: 123456)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "groupId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the API server is running."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "description": "Register a new user. An OTP will be sent to the email for verification."
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"frank@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            },
            "description": "Verify email with OTP code. Use frank@example.com / 123456 from seed data."
          }
        },
        {
          "name": "Login (Alice)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', json.accessToken);",
                  "        console.log('Access token saved');",
                  "    }",
                  "    if (json.refreshToken) {",
                  "        pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "        console.log('Refresh token saved');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as Alice (OWNER of Engineering Team, MEMBER of Marketing Hub). Tokens are auto-saved to collection variables."
          }
        },
        {
          "name": "Login (Bob)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', json.accessToken);",
                  "        console.log('Access token saved');",
                  "    }",
                  "    if (json.refreshToken) {",
                  "        pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "        console.log('Refresh token saved');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as Bob (LEADER of Engineering Team, OWNER of Design Squad). Tokens are auto-saved."
          }
        },
        {
          "name": "Login (Charlie)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', json.accessToken);",
                  "        console.log('Access token saved');",
                  "    }",
                  "    if (json.refreshToken) {",
                  "        pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "        console.log('Refresh token saved');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"charlie@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as Charlie (MEMBER of Engineering Team, OWNER of Marketing Hub). Tokens are auto-saved."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', json.accessToken);",
                  "        console.log('New access token saved');",
                  "    }",
                  "    if (json.refreshToken) {",
                  "        pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "        console.log('New refresh token saved');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh-token"]
            },
            "description": "Get a new access token using the refresh token. Both tokens are auto-saved (rotation)."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Request a password reset OTP. Always returns success (no user enumeration)."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"code\": \"REPLACE_WITH_OTP\",\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Reset password using OTP from email. Replace REPLACE_WITH_OTP with the actual code."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Invalidate the refresh token. The access token will expire naturally (15 min)."
          }
        }
      ],
      "description": "Authentication endpoints. No token required."
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Get the currently logged-in user's profile."
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Updated\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Update the current user's name."
          }
        }
      ],
      "description": "User profile endpoints. Token required."
    },
    {
      "name": "Groups",
      "item": [
        {
          "name": "List My Groups",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.groups && json.groups.length > 0) {",
                  "        pm.collectionVariables.set('groupId', json.groups[0].id);",
                  "        console.log('First group ID saved: ' + json.groups[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups",
              "host": ["{{baseUrl}}"],
              "path": ["groups"]
            },
            "description": "List all groups the current user belongs to. Auto-saves the first group's ID."
          }
        },
        {
          "name": "Create Group",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.group && json.group.id) {",
                  "        pm.collectionVariables.set('groupId', json.group.id);",
                  "        console.log('New group ID saved: ' + json.group.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Project Team\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/groups",
              "host": ["{{baseUrl}}"],
              "path": ["groups"]
            },
            "description": "Create a new group. You become the OWNER automatically. Group ID is auto-saved."
          }
        },
        {
          "name": "Get Group Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}"]
            },
            "description": "Get details of a specific group including members. Must be a member."
          }
        },
        {
          "name": "Update Group",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed Group\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}"]
            },
            "description": "Rename a group. Requires OWNER or LEADER role."
          }
        },
        {
          "name": "Delete Group",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}"]
            },
            "description": "Delete a group permanently. Requires OWNER role."
          }
        }
      ],
      "description": "Group CRUD endpoints. Token required."
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "Add Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.member && json.member.userId) {",
                  "        pm.collectionVariables.set('userId', json.member.userId);",
                  "        console.log('Added member userId saved: ' + json.member.userId);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"diana@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/members",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "members"]
            },
            "description": "Add a user to the group by email. Requires OWNER or LEADER role. User ID is auto-saved."
          }
        },
        {
          "name": "Update Member Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"LEADER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/members/{{userId}}/role",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "members", "{{userId}}", "role"]
            },
            "description": "Change a member's role to LEADER or MEMBER. Requires OWNER role."
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/members/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "members", "{{userId}}"]
            },
            "description": "Remove a member from the group. Requires OWNER or LEADER role."
          }
        }
      ],
      "description": "Group member management. Token required. OWNER or LEADER role needed."
    },
    {
      "name": "Logs",
      "item": [
        {
          "name": "Get Group Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/logs?take=20",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "logs"],
              "query": [
                {
                  "key": "take",
                  "value": "20",
                  "description": "Number of logs to fetch (1-100, default 20)"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "description": "Cursor for pagination (log ID from previous response)",
                  "disabled": true
                }
              ]
            },
            "description": "Get activity logs for a group with cursor-based pagination. Must be a group member."
          }
        }
      ],
      "description": "Activity log endpoints. Token required. Must be a group member."
    }
  ]
}