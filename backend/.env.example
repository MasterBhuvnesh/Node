# Local development (bun run dev) — uses localhost
DATABASE_URL=postgresql://node_user:node_pass@localhost:5433/node_db
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM="App Name <noreply@example.com>"
PORT=3000
NODE_ENV=development

# For Docker: copy this file to .env.docker and change:
#   DATABASE_URL=postgresql://node_user:node_pass@node_postgres:5432/node_db
#   NODE_ENV=production
