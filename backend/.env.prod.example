# Production environment variables
# Copy to .env.prod and fill in real values:  cp .env.prod.example .env.prod

# Database
DB_USER=node_user
DB_PASS=a-strong-password-here
DB_NAME=node_db

# Backend
JWT_SECRET=a-long-random-secret-here
JWT_REFRESH_SECRET=a-different-long-random-secret-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM="App Name <noreply@example.com>"

# Docker image (override with your registry URL)
BACKEND_IMAGE=verma2904/node-backend:latest
